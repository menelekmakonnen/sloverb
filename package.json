{
    "name": "sloverb",
    "productName": "Sloverb",
    "author": "Menelek Makonnen (ICUNI Labs)",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "dist": "vite build && electron-builder",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite --port 4597 --strictPort\" \"wait-on http://localhost:4597 && cross-env VITE_DEV_SERVER_URL=http://localhost:4597 electron .\""
    },
    "build": {
        "appId": "com.icunigroup.sloverb",
        "productName": "Sloverb",
        "mac": {
            "category": "public.app-category.music"
        },
        "win": {
            "target": "nsis",
            "icon": "public/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "directories": {
            "output": "dist-electron"
        },
        "fileAssociations": [
            {
                "ext": [
                    "mp3",
                    "wav",
                    "flac",
                    "m4a",
                    "mp4",
                    "ogg"
                ],
                "name": "Audio File",
                "role": "Viewer"
            }
        ]
    },
    "dependencies": {
        "@ffmpeg/core": "^0.12.10",
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@fontsource/space-mono": "^5.2.9",
        "@fontsource/syne": "^5.2.7",
        "discord-rpc": "^4.0.1",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.7.0",
        "music-metadata": "^11.12.3",
        "play-dl": "^1.9.7",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "youtube-dl-exec": "^3.1.3",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "png-to-ico": "^3.0.1",
        "vite": "^5.0.8",
        "wait-on": "^9.0.4"
    }
}
